{
  "name": "jbyond-prototype",
  "version": "0.2.0",
  "private": true,
  "description": "JByond — 담당자 승인 중심 금융 AI 에이전트 운영 콘솔 프로토타입 (구 JB LocalGuard OS · 정적 MVP + Playwright 검증)",
  "scripts": {
    "dev": "python3 -m http.server 8000 --directory app",
    "build": "python3 scripts/verify_static.py",
    "backend": "node server/index.mjs",
    "backend:test": "node --test tests/backend/*.test.mjs",
    "test": "python3 scripts/verify_static.py",
    "test:e2e": "playwright test",
    "demo:proxy": "node scripts/api-proxy.mjs",
    "demo:ollama": "node scripts/ollama-agent-proxy.mjs",
    "demo:llm": "node scripts/llm-gateway.mjs",
    "test:smoke": "playwright test tests/e2e/jeonse-smoke.spec.js"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0"
  }
}
